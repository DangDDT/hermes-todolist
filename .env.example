# ============================================
# Hermes TodoList — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- PostgreSQL ----
POSTGRES_USER=hermes
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=hermes_todolist

# ---- JWT ----
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_EXPIRY_HOURS=168

# ---- Server ----
SERVER_PORT=8080
LOG_LEVEL=info

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000

# ---- Sentry (optional) ----
SENTRY_DSN=

# ---- VPS Deploy ----
VPS_HOST=your-vps-ip
VPS_USER=deploy
# VPS_SSH_KEY is set in GitHub Secrets, not here

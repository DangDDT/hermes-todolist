                "exec": [
                  "pm.test(\"List tasks (B) - status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"List tasks (B) - should contain only User B's task\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "    pm.expect(jsonData.data).to.have.property('tasks');",
                  "    var tasks = jsonData.data.tasks;",
                  "    pm.expect(tasks).to.be.an('array');",
                  "    // Should not see User A's tasks",
                  "    var taskIdA = pm.collectionVariables.get('task_id_a');",
                  "    var taskIds = tasks.map(function(t) { return t.id; });",
                  "    if (taskIdA) {",
                  "        pm.expect(taskIds).to.not.include(taskIdA);",
                  "    }",
                  "    // Should see User B's own task",
                  "    var taskIdB = pm.collectionVariables.get('task_id_b');",
                  "    if (taskIdB) {",
                  "        pm.expect(taskIds).to.include(taskIdB);",

        {
          "name": "List Tasks (User A) - Should see only A's tasks",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var token = pm.collectionVariables.get('token_a');",
                  "if (token) {",
                  "    pm.request.headers.add({",
                  "        key: 'Cookie',",
                  "        value: 'access_token=' + token",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"List tasks (A) - status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"List tasks (A) - should contain only User A's task\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "    pm.expect(jsonData.data).to.have.property('tasks');",
                  "    var tasks = jsonData.data.tasks;",
                  "    pm.expect(tasks).to.be.an('array');",
                  "    pm.expect(tasks.length).to.be.at.least(1);",
                  "    // Verify all tasks belong to User A",
                  "    tasks.forEach(function(task) {",
                  "        pm.expect(task).to.have.property('title');",
                  "        pm.expect(task).to.have.property('creator_id');",
                  "    });",
                  "    // The task we created should be in the list",
                  "    var taskIds = tasks.map(function(t) { return t.id; });",
                  "    var taskIdA = pm.collectionVariables.get('task_id_a');",
                  "    if (taskIdA) {",
                  "        pm.expect(taskIds).to.include(taskIdA);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["tasks"]
            },
            "description": "List tasks as User A. Should only see tasks created by User A (filtered by creator_id)."
          }
        },
